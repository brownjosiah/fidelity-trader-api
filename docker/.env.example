# Fidelity Trader Service — Environment Variables
# Copy to .env and fill in values: cp .env.example .env

# --- Network ---
# Bind address: use 0.0.0.0 for Docker, 127.0.0.1 for local-only
FTSERVICE_HOST=0.0.0.0
# Service port (default 8787)
FTSERVICE_PORT=8787

# --- Security ---
# Fernet encryption key for stored credentials.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FTSERVICE_ENCRYPTION_KEY=

# Require API key for all requests (set false for local-only use)
FTSERVICE_API_KEY_REQUIRED=true

# --- Session ---
# Automatically re-authenticate when Fidelity session expires
FTSERVICE_AUTO_REAUTH=true

# Session keep-alive interval in seconds (default 300 = 5 min)
FTSERVICE_SESSION_KEEPALIVE_INTERVAL=300

# --- Trading ---
# Enable live order placement (default false = preview/dry-run only)
FTSERVICE_LIVE_TRADING=false

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
FTSERVICE_LOG_LEVEL=INFO

# --- Database ---
# Path to SQLite database (relative to /app inside container)
FTSERVICE_DB_PATH=data/ftservice.db
